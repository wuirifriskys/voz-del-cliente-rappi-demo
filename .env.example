# Copy this file to .env and fill with real values. NEVER commit .env.
# All values below are placeholders — do not commit real secrets here either.

# Anthropic API key — used by classifier + clusterer agents
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER

# Apify API token — used by review scrapers
APIFY_TOKEN=apify_api_PLACEHOLDER

# Supabase project URL (public, OK to expose)
SUPABASE_URL=https://PLACEHOLDER.supabase.co

# Supabase anon key (public — RLS-gated, OK to expose)
SUPABASE_ANON_KEY=PLACEHOLDER_ANON_KEY

# Supabase service role key — SECRET, server-side only
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SERVICE_ROLE_KEY

# Telegram bot token
TELEGRAM_BOT_TOKEN=PLACEHOLDER:TELEGRAM_TOKEN
